# OS and editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Local configuration and secrets
.env
.env.*
!.env.example

# Python bytecode and tool caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
