htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Build and package artifacts
build/
dist/
*.egg-info/
pip-wheel-metadata/

# Generated runtime outputs.
# Keep checked-in example contracts and placeholders only.
outputs/generated/*
!outputs/generated/.gitkeep
outputs/demo/*
!outputs/demo/api_response.example.json
!outputs/demo/dashboard_view_model.example.json
